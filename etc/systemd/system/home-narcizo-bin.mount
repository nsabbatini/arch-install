[Unit]
Description=NFS mount (/homes/narcizo/bin on elefante)
After=wait-for-ping.service

[Mount]
What=192.168.1.104:/homes/narcizo/bin
Where=/home/narcizo/bin
Type=nfs4
TimeoutSec=20s
Options=_netdev,auto
#LazyUnmount=true
ForceUnmount=true

[Install]
WantedBy=remote-fs.target
WantedBy=multi-user.target
