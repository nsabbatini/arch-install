[Unit]
Description=NFS mount (linux-backup on cobra)
After=network-online.target rpc-gssd.service auth-rpcgss-module.service
Requires=rpc-gssd.service

[Mount]
What=192.168.1.84:/srv/nfsv4/backups
Where=/mnt/backups
Type=nfs4
TimeoutSec=20s
Options=_netdev,auto,sec=krb5p
LazyUnmount=true
ForceUnmount=true

[Install]
WantedBy=remote-fs.target
WantedBy=multi-user.target
